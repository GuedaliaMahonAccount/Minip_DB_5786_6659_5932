--
-- Name: hr_employee_overview; Type: VIEW; Schema: public; Owner: admin
--

CREATE VIEW public.hr_employee_overview AS
 SELECT e.employee_id,
    (((e.first_name)::text || ' '::text) || (e.last_name)::text) AS employee_full_name,
    e.phone_number,
    e.birth_date,
    d.dept_name AS department_name,
    d.location AS department_location,
    r.role_title,
    ec.salary,
    ec.start_date AS contract_start_date,
    o.office_name
   FROM ((((public.employee e
     JOIN public.department d ON ((e.department_id = d.department_id)))
     JOIN public.role r ON ((e.role_id = r.role_id)))
     LEFT JOIN public.employee_contract ec ON ((e.contract_id = ec.contract_id)))
     LEFT JOIN public.office o ON ((e.department_id = o.department_id)));


ALTER VIEW public.hr_employee_overview OWNER TO admin;

