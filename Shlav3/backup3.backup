--

CREATE TABLE public.veterinarian (
    vetid integer NOT NULL,
    firstname character varying(100) NOT NULL,
    lastname character varying(100) NOT NULL,
    licensenumber character varying(50) NOT NULL,
    specialization character varying(100),
    hiredate date NOT NULL,
    employee_id integer,
    CONSTRAINT veterinarian_hiredate_check CHECK ((hiredate <= CURRENT_DATE))
);


ALTER TABLE public.veterinarian OWNER TO admin;

--
-- Name: vet_staff_integrated_view; Type: VIEW; Schema: public; Owner: admin
--

CREATE VIEW public.vet_staff_integrated_view AS
 SELECT v.vetid,
    v.firstname AS vet_first_name,
    v.lastname AS vet_last_name,
    v.licensenumber,
    v.specialization,
    v.hiredate AS vet_hire_date,
    e.employee_id,
    e.phone_number AS employee_phone,
    d.dept_name AS hr_department,
    r.role_title AS hr_role,
    ec.salary AS employee_salary,
    ec.start_date AS contract_start,
    ( SELECT count(*) AS count
           FROM public.medicalvisit mv
          WHERE (mv.vetid = v.vetid)) AS total_visits
   FROM ((((public.veterinarian v
     LEFT JOIN public.employee e ON ((v.employee_id = e.employee_id)))
     LEFT JOIN public.department d ON ((e.department_id = d.department_id)))
     LEFT JOIN public.role r ON ((e.role_id = r.role_id)))
     LEFT JOIN public.employee_contract ec ON ((e.contract_id = ec.contract_id)));


ALTER VIEW public.vet_staff_integrated_view OWNER TO admin;

--
-- Name: vet_visit_summary; Type: VIEW; Schema: public; Owner: admin
--

CREATE VIEW public.vet_visit_summary AS
 SELECT mv.visitid,
    a.name AS animal_name,
    a.species AS animal_species,
    a.gender AS animal_gender,
    (((v.firstname)::text || ' '::text) || (v.lastname)::text) AS vet_full_name,
    v.specialization AS vet_specialization,
    mv.visitdate,
    mv.reason,
    mv.cost,
    ( SELECT count(*) AS count
           FROM public.mirsham_visit_treatment mvt
          WHERE (mvt.visitid = mv.visitid)) AS treatment_count
   FROM ((public.medicalvisit mv
     JOIN public.animal a ON ((mv.animalid = a.animalid)))
     JOIN public.veterinarian v ON ((mv.vetid = v.vetid)));


ALTER VIEW public.vet_visit_summary OWNER TO admin;

